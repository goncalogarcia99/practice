{
  "compilerOptions": { // https://www.typescriptlang.org/tsconfig
    "target": "es2025",
    "module": "nodenext",
    "declaration": true, // Generate type declarations (.d.ts files).
    "importHelpers": true, // tslib required as a dependency!
	"rootDir": "src",
    "outDir": "dist",
    "removeComments": true,
    "sourceMap": true, // For debugging (.js.map files).
    "esModuleInterop": true, // Enables allowSyntheticDefaultImports (disabled by default).
    "forceConsistentCasingInFileNames": true,
    "noImplicitReturns": true,
    "strict": true,
    // "strictPropertyInitialization": false,
    "incremental": true, // Speeds up the build process - not everything is rebuilt (tsconfig.tsbuildinfo files).
    "skipLibCheck": true // Enabling this option speeds up the build process - .d.ts files are not type checked.
  },
  "include": [
    "src"
  ]
}